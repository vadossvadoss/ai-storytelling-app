NEXT_PUBLIC_API_URL=http://localhost:4000
# Production (optional override — defaults to Railway URL when NODE_ENV=production):
# NEXT_PUBLIC_API_URL=https://ai-storytelling-backend-production.up.railway.app

DATABASE_URL=postgresql://user:password@localhost:5432/ai_storytelling
ANTHROPIC_API_KEY=sk-ant-...
NEXTAUTH_SECRET=your-secret-here
# Local dev only — on Vercel use https://your-app.vercel.app (or rely on auth-env.ts + VERCEL_URL)
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
